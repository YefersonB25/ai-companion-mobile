{
  "expo": {
    "name": "AI Companion",
    "slug": "ai-companion-mobile",
    "version": "1.0.10",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "scheme": "ai-companion",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-speech-recognition",
        {
          "microphonePermission": "Permite que AI Companion escuche tu voz para responder a tus preguntas.",
          "speechRecognitionPermission": "Permite el reconocimiento de voz para que puedas hablar con AI Companion."
        }
      ]
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.aicompanion.mobile",
      "buildNumber": "1",
      "infoPlist": {
        "NSSpeechRecognitionUsageDescription": "Permite el reconocimiento de voz para que puedas hablar con AI Companion.",
        "NSMicrophoneUsageDescription": "Permite que AI Companion escuche tu voz para responder a tus preguntas."
      }
    },
    "android": {
      "package": "com.aicompanion.mobile",
      "versionCode": 11,
      "adaptiveIcon": {
        "backgroundColor": "#6366f1",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.RECORD_AUDIO"
      ]
    },
    "web": {
      "bundler": "metro",
      "favicon": "./assets/favicon.png"
    },
    "updates": {
      "enabled": false
    },
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "7d1a5472-80fc-439d-b111-8d9cd254db4c"
      }
    },
    "owner": "yefbolcar"
  }
}